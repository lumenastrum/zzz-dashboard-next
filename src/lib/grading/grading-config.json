{
  "version": 1,
  "_comment": "ZZZ disc-grading config for the Soundsystem dashboard. OUR OWN archetype weights (not interknot's). Edit freely — the engine is data-driven and re-grades live. Scale mirrors interknot's SSS…E for vanity.",

  "rollModel": {
    "_comment": "S-rank disc: 4 base substats, +1 upgrade roll every 3 levels to +15 = 5 upgrades. One substat caps at 6 rolls (PropertyLevel). Total rolls on a maxed disc = 9.",
    "maxLevel": 15,
    "baseSubs": 4,
    "maxRollsPerSub": 6,
    "totalRollsAtMax": 9
  },

  "mainWeightMultiplier": 2.5,
  "partnerBoost": 4.25,

  "scale": [
    { "letter": "SSS", "min": 92.5, "color": "#ffe08a" },
    { "letter": "SS",  "min": 85.0, "color": "#ffd84a" },
    { "letter": "S",   "min": 77.5, "color": "#ffb43c" },
    { "letter": "A",   "min": 67.5, "color": "#b06bff" },
    { "letter": "B",   "min": 55.0, "color": "#6aa6ff" },
    { "letter": "C",   "min": 42.5, "color": "#d8d8de" },
    { "letter": "D",   "min": 27.5, "color": "#9a9aa6" },
    { "letter": "E",   "min": 0.0,  "color": "#ff4d52" }
  ],

  "sectionToArchetype": {
    "ATTACK": "attack",
    "ANOMALY": "anomaly",
    "STUN": "stun",
    "SUPPORT": "support",
    "RUPTURE": "attack"
  },

  "archetypes": {
    "anomaly": {
      "label": "Anomaly DPS",
      "pairs": ["ATK%", "Anomaly Proficiency"],
      "weights": {
        "Anomaly Proficiency": 3.5, "ATK%": 3.5,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "CRIT Rate": 0, "CRIT DMG": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "Anomaly Proficiency": 3, "ATK%": 2 },
        "5": { "Attribute DMG": 3, "PEN Ratio": 3, "ATK%": 2 },
        "6": { "Anomaly Proficiency": 3, "ATK%": 2.5, "Anomaly Mastery": 2 }
      }
    },

    "attack": {
      "label": "Crit DPS",
      "pairs": ["CRIT Rate", "CRIT DMG"],
      "weights": {
        "CRIT DMG": 3.5, "CRIT Rate": 3.0, "ATK%": 3.0,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "Anomaly Proficiency": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 3, "CRIT Rate": 3, "ATK%": 2 },
        "5": { "Attribute DMG": 3, "ATK%": 2, "PEN Ratio": 2 },
        "6": { "ATK%": 3, "PEN Ratio": 2 }
      }
    },

    "stun": {
      "label": "Stun / Impact",
      "pairs": ["CRIT Rate", "CRIT DMG"],
      "weights": {
        "CRIT DMG": 3.0, "CRIT Rate": 3.0, "ATK%": 3.0,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "Anomaly Proficiency": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 3, "CRIT Rate": 3, "ATK%": 2.5 },
        "5": { "ATK%": 2.5, "Attribute DMG": 2.5, "PEN Ratio": 2 },
        "6": { "Impact": 3, "ATK%": 2.5, "Energy Regen": 2 }
      }
    },

    "support": {
      "label": "Support",
      "pairs": ["ATK%", "CRIT DMG"],
      "weights": {
        "ATK%": 3.0, "CRIT DMG": 2.0, "CRIT Rate": 2.0,
        "Anomaly Proficiency": 1.5, "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "HP%": 0.5, "DEF%": 0.5, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 2.5, "ATK%": 2.5, "Anomaly Proficiency": 2 },
        "5": { "ATK%": 2.5, "Attribute DMG": 2.5 },
        "6": { "Energy Regen": 3, "ATK%": 2.5, "Anomaly Proficiency": 2 }
      }
    }
  },

  "agentOverrides": {
    "_comment": "Per-agent tweaks. archetype overrides section mapping; weights merge over the archetype's weights. targets = per-agent Levels goalposts; numbers only (unit comes from global LEVEL_CFG). A CRIT Rate `cap` arms the hard clamp: when the character-screen CRIT Rate is at/over cap, extra CRIT Rate rolls score 0 and the verdict redirects to CRIT DMG. Calibrated 2026-06-21 from Prydwen endgame stats — see docs/grading-calibration.md.",
    "Ye Shunguang": { "archetype": "attack", "targets": {
      "ATK": { "target": 3000, "full": 3800 },
      "CRIT Rate": { "target": 48, "cap": 50, "full": 55 },
      "CRIT DMG": { "target": 190, "full": 240 }
    } },
    "Evelyn": { "archetype": "attack", "targets": {
      "ATK": { "target": 2900, "full": 3600 },
      "CRIT Rate": { "target": 75, "cap": 80, "full": 85 },
      "CRIT DMG": { "target": 180, "full": 240 }
    } },
    "Ellen": { "archetype": "attack", "targets": {
      "ATK": { "target": 2800, "full": 3400 },
      "CRIT Rate": { "target": 80, "cap": 85, "full": 95 },
      "CRIT DMG": { "target": 150, "full": 200 }
    } },
    "Soldier 0 Anby": { "archetype": "attack", "targets": {
      "ATK": { "target": 3000, "full": 3600 },
      "CRIT Rate": { "target": 68, "cap": 78, "full": 85 },
      "CRIT DMG": { "target": 180, "full": 240 }
    } },
    "Seed": { "archetype": "attack", "targets": {
      "ATK": { "target": 2850, "full": 3400 },
      "CRIT Rate": { "target": 82, "cap": 90, "full": 95 },
      "CRIT DMG": { "target": 130, "full": 180 }
    } },
    "_cissia_note": "Cissia is gear-CR / passive-fed-CDMG (Festering Venom self-grants +50% CRIT DMG, off-screen combat) so her CRIT DMG goalpost is LOW (110+) and CRIT Rate is the gear stat (50-57 w/ signature, no mechanical cap). Disk 6 main is ENERGY REGEN, not ATK%: her Core Passive scales squad DEF-Ignore with ER above 1.4, maxing at 12.88% DEF-Ignore at ER 3.68 (1.4 + 19 steps of 0.52% per 0.12 ER) — that's the Energy Regen `cap`. Prydwen 2.7.",
    "Cissia": { "archetype": "attack", "mainStatPoints": { "6": { "Energy Regen": 3 } }, "targets": {
      "ATK": { "target": 2600, "full": 3200 },
      "CRIT Rate": { "target": 50, "full": 60 },
      "CRIT DMG": { "target": 110, "full": 180 },
      "Energy Regen": { "target": 3.0, "cap": 3.68, "full": 3.8 }
    } },
    "Alice": { "archetype": "anomaly", "targets": {
      "ATK": { "target": 2750, "full": 3300 },
      "Anomaly Proficiency": { "target": 400, "full": 470 },
      "Anomaly Mastery": { "target": 190, "full": 280 }
    } },
    "_miyabi_note": "Miyabi is a CRIT-SCALING anomaly, NOT an AP-scaling one: her Icefire passive converts CRIT Rate → Frost Anomaly Buildup Rate (100% of CRIT Rate, cap 80% — that's where her CRIT Rate cap comes from), and her Frost anomaly procs CAN CRIT, so CRIT DMG is her damage multiplier, not Anomaly Proficiency. Weights are CRIT-priority; do NOT revert AP to the top. relevant stays ATK/CRIT Rate/CRIT DMG (no AP/AM goalposts).",
    "Miyabi": { "archetype": "anomaly", "weights": { "CRIT Rate": 3.5, "CRIT DMG": 3.5, "ATK%": 3.0, "Anomaly Proficiency": 1.0 }, "mainStatPoints": { "4": { "CRIT Rate": 3, "CRIT DMG": 3 } }, "targets": {
      "ATK": { "target": 2700, "full": 3300 },
      "CRIT Rate": { "target": 80, "cap": 80, "full": 90 },
      "CRIT DMG": { "target": 160, "full": 220 },
      "Anomaly Proficiency": { "target": 230, "full": 380 },
      "Anomaly Mastery": { "target": 116, "full": 200 }
    } },
    "Jane Doe": { "archetype": "anomaly", "targets": {
      "ATK": { "target": 2700, "full": 3200 },
      "Anomaly Proficiency": { "target": 420, "full": 480 },
      "Anomaly Mastery": { "target": 192, "full": 280 }
