  "wengines": {
    "_comment": "W-Engine reference data keyed by engine name. Enka imports only carry name/rank/refine, so base ATK / advanced stat / combat passive live here — the cartridge card AND the Sheet-vs-Effective layer read from this. `passive` lists ONLY in-combat conditional buffs (Effective = Sheet + these); sheet-scope base/advanced are already baked into the seeded character-screen value and shown on the cartridge.",
    "Practiced Perfection": {
      "base": { "ATK": 713 },
      "advanced": { "label": "Anomaly Prof +32%" },
      "passive": [
        { "label": "+60 Anomaly Mastery", "kind": "stat", "stat": "Anomaly Mastery", "value": 60, "unit": "", "scope": "combat" },
        { "label": "+45 Anomaly Proficiency (4 stacks)", "kind": "stat", "stat": "Anomaly Proficiency", "value": 45, "unit": "", "scope": "combat" }
      ]
    },
    "Hailstorm Shrine": {
      "_comment": "Miyabi signature (S), R1 (Andres runs ALL signatures at R1). base ATK + advanced CRIT Rate 24% are on the character screen (baked into the seeded sheet); refine scales ONLY the passive, not base/advanced. Passive CRIT DMG +50% (R1) is NOT on screen — reconciled against Miyabi's real substats (base50 + B&BS-2pc16 + 12 CDMG rolls = her 123.6 sheet) — so it layers on Effective. Ice DMG is a conditional dmg chip. R-scaling for reference: CRIT DMG 50/57/65/72/80, Ice DMG/stack 20/23/26/29/32.",
      "base": { "ATK": 713 },
      "advanced": { "label": "CRIT Rate +24%" },
      "passive": [
        { "label": "+50% CRIT DMG", "kind": "stat", "stat": "CRIT DMG", "value": 50, "unit": "%", "scope": "combat" },
        { "label": "+40% Ice DMG (2 stacks · EX/anomaly, 15s)", "kind": "dmg", "stat": "Ice DMG", "value": 40, "unit": "%", "scope": "combat", "cond": true }
      ]
    }
