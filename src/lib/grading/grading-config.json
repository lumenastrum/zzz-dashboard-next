    "Yixuan": { "archetype": "attack", "weights": { "HP%": 3.0, "PEN Ratio": 0, "Flat PEN": 0 }, "mainStatPoints": { "6": { "HP%": 3 } }, "targets": {
      "ATK": { "target": 1900, "full": 2400 },
      "CRIT Rate": { "target": 85, "cap": 90, "full": 95 },
      "CRIT DMG": { "target": 150, "full": 200 },
      "HP": { "target": 17000, "full": 21000 },
      "Sheer Force": { "target": 2250, "full": 2600 }
    } },
    "Yidhari": { "archetype": "attack", "weights": { "HP%": 3.0, "PEN Ratio": 0, "Flat PEN": 0 }, "mainStatPoints": { "6": { "HP%": 3 } }, "targets": {
      "CRIT Rate": { "target": 62, "cap": 66, "full": 75 },
      "CRIT DMG": { "target": 135, "full": 180 },
