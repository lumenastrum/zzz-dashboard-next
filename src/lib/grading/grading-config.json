    "Aria": { "archetype": "anomaly", "targets": {
      "ATK": { "target": 2750, "full": 3300 },
      "Anomaly Proficiency": { "target": 400, "full": 470 },
      "Anomaly Mastery": { "target": 214, "full": 300 }
    } },
    "Velina": { "archetype": "anomaly", "mainStatPoints": { "6": { "Energy Regen": 3 } }, "targets": {
      "ATK": { "target": 2500, "full": 3100 },
      "Anomaly Proficiency": { "target": 375, "full": 460 },
      "Energy Regen": { "target": 2.7, "full": 3.2 }
    } },
    "Burnice": { "archetype": "anomaly", "targets": {
      "ATK": { "target": 2700, "full": 3300 },
      "Anomaly Proficiency": { "target": 375, "full": 450 },
      "Anomaly Mastery": { "target": 153, "full": 260 }
    } },
    "_vivian_note": "Anomaly Proficiency is uniquely premium for Vivian: her Core Passive scales Abloom (the bulk of her DPS) DIRECTLY with AP, so Prydwen flags AP over ATK% in almost all cases — hence the AP weight bump to 4.0 and her LOW ATK goalpost (2000-2400). Disk 6 main is Anomaly Mastery. Prydwen 2.7.",
    "Vivian": { "archetype": "anomaly", "weights": { "Anomaly Proficiency": 4.0 }, "targets": {
      "ATK": { "target": 2200, "full": 2700 },
      "Anomaly Mastery": { "target": 198, "full": 290 },
      "Anomaly Proficiency": { "target": 410, "full": 480 }
