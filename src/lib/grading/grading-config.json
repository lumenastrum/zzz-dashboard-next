{
  "version": 1,
  "_comment": "ZZZ disc-grading config for the Soundsystem dashboard. OUR OWN archetype weights (not interknot's). Edit freely — the engine is data-driven and re-grades live. Scale mirrors interknot's SSS…E for vanity.",

  "rollModel": {
    "_comment": "S-rank disc: 4 base substats, +1 upgrade roll every 3 levels to +15 = 5 upgrades. One substat caps at 6 rolls (PropertyLevel). Total rolls on a maxed disc = 9.",
    "maxLevel": 15,
    "baseSubs": 4,
    "maxRollsPerSub": 6,
    "totalRollsAtMax": 9
  },

  "mainWeightMultiplier": 2.5,
  "partnerBoost": 4.25,

  "scale": [
    { "letter": "SSS", "min": 92.5, "color": "#ffe08a" },
    { "letter": "SS",  "min": 85.0, "color": "#ffd84a" },
    { "letter": "S",   "min": 77.5, "color": "#ffb43c" },
    { "letter": "A",   "min": 67.5, "color": "#b06bff" },
    { "letter": "B",   "min": 55.0, "color": "#6aa6ff" },
    { "letter": "C",   "min": 42.5, "color": "#d8d8de" },
    { "letter": "D",   "min": 27.5, "color": "#9a9aa6" },
    { "letter": "E",   "min": 0.0,  "color": "#ff4d52" }
  ],

  "sectionToArchetype": {
    "ATTACK": "attack",
    "ANOMALY": "anomaly",
    "STUN": "stun",
    "SUPPORT": "support",
    "RUPTURE": "attack"
  },

  "_mainStatRule": "GAME RULE for disc main stats: slot 4 can roll Anomaly Proficiency but NEVER Anomaly Mastery; slot 6 can roll Anomaly Mastery but NEVER Anomaly Proficiency; slot 5 rolls neither. So mainStatPoints['4'] must never list Anomaly Mastery, and mainStatPoints['6'] must never list Anomaly Proficiency — those are impossible mains and would grade a build the game can't produce.",

  "archetypes": {
    "anomaly": {
      "label": "Anomaly DPS",
      "pairs": ["ATK%", "Anomaly Proficiency"],
      "weights": {
        "Anomaly Proficiency": 3.5, "ATK%": 3.5,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "CRIT Rate": 0, "CRIT DMG": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "Anomaly Proficiency": 3, "ATK%": 2 },
        "5": { "Attribute DMG": 3, "PEN Ratio": 3, "ATK%": 2 },
        "6": { "ATK%": 2.5, "Anomaly Mastery": 3 }
      }
    },

    "attack": {
      "label": "Crit DPS",
      "pairs": ["CRIT Rate", "CRIT DMG"],
      "weights": {
        "CRIT DMG": 3.5, "CRIT Rate": 3.0, "ATK%": 3.0,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "Anomaly Proficiency": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 3, "CRIT Rate": 3, "ATK%": 2 },
        "5": { "Attribute DMG": 3, "ATK%": 2, "PEN Ratio": 2 },
        "6": { "ATK%": 3, "PEN Ratio": 2 }
      }
    },

    "stun": {
      "label": "Stun / Impact",
      "pairs": ["CRIT Rate", "CRIT DMG"],
      "weights": {
        "CRIT DMG": 3.0, "CRIT Rate": 3.0, "ATK%": 3.0,
        "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "Anomaly Proficiency": 0, "HP%": 0, "DEF%": 0, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 3, "CRIT Rate": 3, "ATK%": 2.5 },
        "5": { "ATK%": 2.5, "Attribute DMG": 2.5, "PEN Ratio": 2 },
        "6": { "Impact": 3, "ATK%": 2.5, "Energy Regen": 2 }
      }
    },

    "support": {
      "label": "Support",
      "pairs": ["ATK%", "CRIT DMG"],
      "weights": {
        "ATK%": 3.0, "CRIT DMG": 2.0, "CRIT Rate": 2.0,
        "Anomaly Proficiency": 1.5, "PEN Ratio": 1.0, "ATK": 0.5, "Flat PEN": 0.5,
        "HP%": 0.5, "DEF%": 0.5, "HP": 0, "DEF": 0
      },
      "mainStatPoints": {
        "4": { "CRIT DMG": 2.5, "ATK%": 2.5, "Anomaly Proficiency": 2 },
        "5": { "ATK%": 2.5, "Attribute DMG": 2.5 },
        "6": { "Energy Regen": 3, "ATK%": 2.5, "Anomaly Mastery": 2 }
      }
    }
  },

